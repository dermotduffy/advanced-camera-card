{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Rollup",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/run-once.sh",
      "args": ["/tmp/advanced-camera-card-rollup.pid", "10001", "yarn", "start"],
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^bundles",
          "endsPattern": "^created"
        }
      },
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen",
        "instanceLimit": 1
      }
    }
  ]
}
